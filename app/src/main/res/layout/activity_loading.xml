<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_loading_gradient">

    <!-- ── Marca de agua grande "2" al centro derecha ── -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="2"
        android:textSize="360sp"
        android:textStyle="bold|italic"
        android:textColor="#15FFFFFF"
        android:includeFontPadding="false"
        android:translationX="60dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── Número "01" decorativo abajo derecha ── -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="01"
        android:textSize="64sp"
        android:textStyle="bold|italic"
        android:textColor="#33FFFFFF"
        android:layout_marginEnd="22dp"
        android:layout_marginBottom="22dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── Ícono de menú (3 líneas) abajo izquierda ── -->
    <ImageView
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:src="@drawable/ic_menu_lines"
        android:layout_marginStart="22dp"
        android:layout_marginBottom="34dp"
        android:alpha="0.7"
        app:tint="#FFFFFF"
        android:contentDescription=""
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- ═══════════════════════════════════════════════════════
         BLOQUE CENTRAL: logo + textos.
         Centrado en la mitad superior-media de la pantalla.
         ═══════════════════════════════════════════════════════ -->

    <!-- Logo verde cuadrado -->
    <FrameLayout
        android:id="@+id/logoContainer"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:background="@drawable/bg_logo_square"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvLogoText"
        app:layout_constraintVertical_chainStyle="packed"
        app:layout_constraintVertical_bias="0.32">

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_sports_cluster"
            app:tint="@color/dc_blue_dark"
            android:contentDescription="" />
    </FrameLayout>

    <TextView
        android:id="@+id/tvLogoText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="DEPORTE"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@android:color/white"
        android:letterSpacing="0.15"
        android:layout_marginTop="18dp"
        app:layout_constraintTop_toBottomOf="@id/logoContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvLogoSubtext" />

    <TextView
        android:id="@+id/tvLogoSubtext"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CONNECT"
        android:textSize="12sp"
        android:textColor="#AACCDDFF"
        android:letterSpacing="0.3"
        app:layout_constraintTop_toBottomOf="@id/tvLogoText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvWelcome" />

    <TextView
        android:id="@+id/tvWelcome"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="¡Bienvenido a la red!"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@android:color/white"
        android:layout_marginTop="36dp"
        app:layout_constraintTop_toBottomOf="@id/tvLogoSubtext"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvLoadingMessage" />

    <TextView
        android:id="@+id/tvLoadingMessage"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Preparando tu experiencia\ndeportiva personalizada..."
        android:textSize="14sp"
        android:textColor="#CCCCDFFF"
        android:gravity="center"
        android:lineSpacingMultiplier="1.4"
        android:layout_marginTop="10dp"
        android:layout_marginStart="40dp"
        android:layout_marginEnd="40dp"
        app:layout_constraintTop_toBottomOf="@id/tvWelcome"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- ═══════════════════════════════════════════════════════
         BLOQUE INFERIOR: progreso + tags + estado.
         Anclado a la parte de ABAJO de la pantalla, ocupando
         el espacio que antes quedaba vacío.
         ═══════════════════════════════════════════════════════ -->

    <LinearLayout
        android:id="@+id/bottomBlock"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="90dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ProgressBar
            android:id="@+id/progressBar"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:max="100"
            android:progress="0"
            android:progressDrawable="@drawable/bg_progress_gradient"
            android:layout_marginStart="40dp"
            android:layout_marginEnd="40dp" />

        <!-- Tags con íconos -->
        <LinearLayout
            android:id="@+id/layoutTags"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="28dp">

            <include
                android:id="@+id/tagCercania"
                layout="@layout/item_loading_tag" />

            <Space
                android:layout_width="10dp"
                android:layout_height="match_parent" />

            <include
                android:id="@+id/tagEquipos"
                layout="@layout/item_loading_tag" />

            <Space
                android:layout_width="10dp"
                android:layout_height="match_parent" />

            <include
                android:id="@+id/tagPartidas"
                layout="@layout/item_loading_tag" />
        </LinearLayout>

        <!-- Estado sincronización -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="24dp">

            <View
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/bg_pulse_dot"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/tvSyncStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sincronizando pistas locales en Santiago"
                android:textSize="12sp"
                android:textColor="#AACCDDFF" />
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
