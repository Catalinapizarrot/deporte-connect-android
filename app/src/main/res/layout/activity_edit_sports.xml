<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F2F5">

    <!-- Header fijo arriba -->
    <LinearLayout
        android:id="@+id/headerSports"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="14dp"
        android:paddingTop="20dp"
        android:background="@android:color/white"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/ivBackSports"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="#111111"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Volver" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mis deportes"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#111111" />

            <TextView
                android:id="@+id/tvSportsCounter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Selecciona al menos 1 deporte"
                android:textSize="12sp"
                android:textColor="#888888"
                android:layout_marginTop="2dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Scroll de deportes -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/headerSports"
        app:layout_constraintBottom_toTopOf="@id/btnSaveSports"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Toca los deportes que quieres practicar. Puedes agregar o quitar los que prefieras, manteniendo al menos uno."
                android:textSize="13sp"
                android:textColor="#666666"
                android:lineSpacingMultiplier="1.3"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/tvLoadingSports"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Cargando deportes..."
                android:textSize="13sp"
                android:textColor="#888888"
                android:gravity="center"
                android:paddingTop="30dp"
                android:paddingBottom="30dp" />

            <GridLayout
                android:id="@+id/containerSports"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Botón guardar fijo abajo -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSaveSports"
        android:layout_width="0dp"
        android:layout_height="54dp"
        android:text="Guardar cambios"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="@android:color/white"
        app:backgroundTint="@color/dc_green"
        app:cornerRadius="14dp"
        android:layout_margin="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
