<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F2F5"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@android:color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Progress bar (paso 2 de 2) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="20dp"
                    android:weightSum="2">

                    <View
                        android:layout_width="0dp"
                        android:layout_height="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_progress_active"
                        android:layout_marginEnd="6dp" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_progress_active"
                        android:layout_marginStart="6dp" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="¿Qué te gusta jugar?"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="@color/dc_blue" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Selecciona tus deportes favoritos para personalizar tu experiencia."
                    android:textSize="13sp"
                    android:textColor="#666666"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="20dp" />

                <!-- Loading state inicial -->
                <TextView
                    android:id="@+id/tvLoadingSports"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Cargando deportes..."
                    android:textSize="13sp"
                    android:textColor="#888888"
                    android:gravity="center"
                    android:padding="20dp" />

                <!-- ═══ Grid 2 columnas para las cards de deportes ═══ -->
                <GridLayout
                    android:id="@+id/containerSports"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="2"
                    android:useDefaultMargins="false" />

                <!-- Banner motivacional compacto -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginTop="18dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#1E3A8A">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="Únete a la comunidad de deportistas más grande"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@android:color/white"
                        android:gravity="center"
                        android:padding="12dp" />
                </androidx.cardview.widget.CardView>

                <!-- Botón Finalizar -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnFinishProfile"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:text="Finalizar  ✓"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/white"
                    android:textAllCaps="false"
                    android:layout_marginTop="18dp"
                    app:backgroundTint="#16A34A"
                    app:cornerRadius="14dp"
                    app:elevation="0dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PASO 2 DE 2"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#888888"
                    android:letterSpacing="0.15"
                    android:layout_marginTop="14dp"
                    android:layout_gravity="center" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
