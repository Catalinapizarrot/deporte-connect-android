<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="14dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@android:color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Banda superior (cambia de color según destacado o no) -->
        <View
            android:id="@+id/cardTopStripe"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:background="@color/dc_green" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Cabecera: icono deporte + título + badge estado -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <FrameLayout
                    android:id="@+id/sportIconContainer"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_sport_icon_default">

                    <ImageView
                        android:id="@+id/ivSportIcon"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:contentDescription=""
                        android:src="@drawable/ic_soccer"
                        app:tint="@color/dc_green" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">

                    <TextView
                        android:id="@+id/tvCardTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Fútbol 7"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:textColor="#111111" />

                    <TextView
                        android:id="@+id/tvCardLocation"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="📍 La Cisterna"
                        android:textSize="12sp"
                        android:textColor="#666666"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvCardBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ACTIVO"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="@color/dc_green"
                    android:letterSpacing="0.1"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:background="@drawable/bg_badge_active" />
            </LinearLayout>

            <!-- Datos del partido: fecha y hora -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="12dp">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_calendar"
                    app:tint="#666666"
                    android:contentDescription="" />

                <TextView
                    android:id="@+id/tvCardDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hoy, 19:00 hrs"
                    android:textSize="13sp"
                    android:textColor="#666666"
                    android:textStyle="bold"
                    android:layout_marginStart="6dp" />
            </LinearLayout>

            <!-- Info participantes -->
            <TextView
                android:id="@+id/tvCardParticipants"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="6 / 14 participantes"
                android:textSize="12sp"
                android:textColor="#999999"
                android:layout_marginTop="6dp" />

            <!-- Botones: VER CHAT + VER DETALLE -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="14dp"
                android:weightSum="2">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCardChat"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="VER CHAT"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/white"
                    app:backgroundTint="@color/dc_green"
                    app:cornerRadius="10dp"
                    app:icon="@drawable/ic_chat"
                    app:iconSize="16dp"
                    app:iconTint="@android:color/white"
                    app:iconGravity="textStart"
                    android:layout_marginEnd="6dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCardDetail"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="VER DETALLE"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#111111"
                    app:strokeColor="#D1D5DB"
                    app:cornerRadius="10dp"
                    android:layout_marginStart="6dp" />
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>

</androidx.cardview.widget.CardView>
