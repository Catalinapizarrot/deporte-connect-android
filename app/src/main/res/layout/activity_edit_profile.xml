<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F2F5">

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="8dp"
                android:paddingBottom="14dp">

                <ImageView
                    android:id="@+id/ivBackEdit"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_arrow_back"
                    app:tint="#111111"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Volver" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Editar perfil"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#111111"
                    android:layout_marginStart="12dp" />
            </LinearLayout>

            <!-- Aviso de solo lectura -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Estos son tus datos registrados. Por ahora son solo de consulta."
                android:textSize="12sp"
                android:textColor="#888888"
                android:layout_marginBottom="14dp"
                android:lineSpacingMultiplier="1.2" />

            <!-- Card con los campos -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@android:color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Nombre -->
                    <LinearLayout
                        android:id="@+id/rowName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="NOMBRE COMPLETO"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:textColor="#888888"
                            android:letterSpacing="0.1" />

                        <TextView
                            android:id="@+id/tvFieldName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textSize="15sp"
                            android:textColor="#111111"
                            android:layout_marginTop="3dp"
                            android:paddingTop="10dp"
                            android:paddingBottom="10dp"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:background="@drawable/bg_readonly_field" />
                    </LinearLayout>

                    <!-- Email -->
                    <LinearLayout
                        android:id="@+id/rowEmail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="CORREO"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:textColor="#888888"
                            android:letterSpacing="0.1" />

                        <TextView
                            android:id="@+id/tvFieldEmail"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textSize="15sp"
                            android:textColor="#111111"
                            android:layout_marginTop="3dp"
                            android:paddingTop="10dp"
                            android:paddingBottom="10dp"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:background="@drawable/bg_readonly_field" />
                    </LinearLayout>

                    <!-- Teléfono -->
                    <LinearLayout
                        android:id="@+id/rowPhone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TELÉFONO"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:textColor="#888888"
                            android:letterSpacing="0.1" />

                        <TextView
                            android:id="@+id/tvFieldPhone"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textSize="15sp"
                            android:textColor="#111111"
                            android:layout_marginTop="3dp"
                            android:paddingTop="10dp"
                            android:paddingBottom="10dp"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:background="@drawable/bg_readonly_field" />
                    </LinearLayout>

                    <!-- Edad -->
                    <LinearLayout
                        android:id="@+id/rowAge"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="EDAD"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:textColor="#888888"
                            android:letterSpacing="0.1" />

                        <TextView
                            android:id="@+id/tvFieldAge"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textSize="15sp"
                            android:textColor="#111111"
                            android:layout_marginTop="3dp"
                            android:paddingTop="10dp"
                            android:paddingBottom="10dp"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:background="@drawable/bg_readonly_field" />
                    </LinearLayout>

                    <!-- Fecha de nacimiento -->
                    <LinearLayout
                        android:id="@+id/rowBirth"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="FECHA DE NACIMIENTO"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:textColor="#888888"
                            android:letterSpacing="0.1" />

                        <TextView
                            android:id="@+id/tvFieldBirth"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textSize="15sp"
                            android:textColor="#111111"
                            android:layout_marginTop="3dp"
                            android:paddingTop="10dp"
                            android:paddingBottom="10dp"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:background="@drawable/bg_readonly_field" />
                    </LinearLayout>

                    <!-- Género -->
                    <LinearLayout
                        android:id="@+id/rowGender"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="GÉNERO"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:textColor="#888888"
                            android:letterSpacing="0.1" />

                        <TextView
                            android:id="@+id/tvFieldGender"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textSize="15sp"
                            android:textColor="#111111"
                            android:layout_marginTop="3dp"
                            android:paddingTop="10dp"
                            android:paddingBottom="10dp"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:background="@drawable/bg_readonly_field" />
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
