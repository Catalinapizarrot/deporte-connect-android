<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="45"
                android:startColor="#E7F5E7"
                android:centerColor="#D4EBC4"
                android:endColor="#BFDDAA" />
            <corners android:radius="12dp" />
        </shape>
    </item>
    <!-- Líneas simulando calles -->
    <item android:top="30dp" android:bottom="30dp">
        <shape android:shape="rectangle">
            <stroke android:width="2dp" android:color="#AAFFFFFF" />
            <corners android:radius="12dp" />
        </shape>
    </item>
</layer-list>
